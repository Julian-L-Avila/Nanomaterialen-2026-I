@article{lakheraIndole7carboxaldehydeFunctionalizedSilver2025,
  title = {Indole-7-Carboxaldehyde Functionalized Silver and Gold Nanoparticles as Novel Metal-Organic Laser Power Limiting Composites},
  author = {Lakhera, Shradha and Rana, Meenakshi and Dhanusha, A. and Girisun, T.C. Sabari and Sharma, Shruti and Chowdhury, Papia},
  year = 2025,
  month = may,
  journal = {Photonics and Nanostructures - Fundamentals and Applications},
  volume = {64},
  pages = {101386},
  issn = {15694410},
  doi = {10.1016/j.photonics.2025.101386},
  abstract = {Efforts were done to enhance the nonlinear optical and optical power limiting responses of Indole-7carboxaldehyde (I7C) after the addition of silver and gold nanoparticles. The investigations were done theoretically as well as experimentally. The reactivity parameters and potential surfaces established strong intermolecular charge interactions between metal trimer and I7C. The diffraction pattern for both I7C+AgNPs and I7C+AuNPs indicated the perfect crystallinity of the samples. The band gap of I7C+AgNPs (2.08 eV) was less than that of I7C+AuNPs (2.34 eV). The polarizability of I7C was enhanced after the addition of gold and silver nanoparticles. The value of first-order hyperpolarizability of probe I7C was observed as 4.24 \texttimes{} 10 30 esu which was increased to ten times for I7C+AgNPs and eighteen times for I7C+AuNPs. The increased value of first-order hyperpolarizability supported enhanced nonlinear optical characteristics of I7C+AgNPs and I7C+AuNPs. Further, the reduction in experimentally obtained optical limiting threshold and increment in the nonlinear absorption coefficient reflects early attenuation of the nonlinear optical and enhanced optical limiting activity of I7C+AgNPs and I7C+AuNPs.},
  langid = {english},
  keywords = {AuNPs,Composites,Indole-7-carboxaldehyde,nonlinear-optics,Optical limiting,topic/silver-nanoparticles},
  file = {/home/oel/Dokumente/Papers/Lakhera et al.2025 - Indole-7-carboxaldehyde functionalized silver and gold nanoparticles as novel metal-organic laser po.pdf}
}

@article{lakheraLowtemperatureChemicalSynthesis2025,
  title = {Low-Temperature Chemical Synthesis and Stabilization of Silver Nanoparticles for Optical Power Limiting Applications},
  author = {Lakhera, Shradha and Dhuliya, Vivek and Rana, Meenakshi and Purohit, L.P.},
  year = 2025,
  month = sep,
  journal = {Photonics and Nanostructures - Fundamentals and Applications},
  volume = {66},
  pages = {101434},
  issn = {15694410},
  doi = {10.1016/j.photonics.2025.101434},
  abstract = {Chemical synthesis of silver nanoparticles (AgNPs) was performed using a chemical reduction method and its optical limiting activity is discussed in this article. The prepared AgNPs were tested under laser light and showed a clear path of the laser light indicating the dispersion of the laser beam via the nano-range particles. The morphological and energy dispersive spectra indicated the availability of AgNPs with a particle size of 3--13 nm. The absorption spectra of the prepared AgNPs stabilized by polyvinyl pyrrolidine confirmed that the AgNPs with 0.5 ml polyvinyl pyrrolidine were the most stable. The prepared AgNPs were stable for up to 60 days. The band gap of the prepared AgNPs was confirmed as 2.4 eV. The Fourier-transform Infrared spectra confirmed the stretching vibrations of the C----O and O-H bonds. Field emission scanning electron microscopy images confirms the formation of AgNPs and the elemental composition confirmed that the prepared AgNPs has a weight percentage of 24 \% Ag atoms. Tunneling electron microscopy analysis confirmed that the average particle size of AgNPs was 9 nm. The diffraction pattern obtained indicates the Face-centered cubic crystal structure of the AgNPs. In the Z-scan experiment, a valley-like pattern with a minimum at the origin was observed for the normalized transmittance versus distance (Z(mm)). The optical limiting pattern decreases the transmittance with increasing input intensity. The results reproduced by Z-scan analysis shows the optical limiting characteristics of the prepared AgNPs which can be employed for the fabrication of laser safety devices.},
  langid = {english},
  keywords = {nonlinear-optics,Optical limiting,topic/silver-nanoparticles,Z-Scan},
  file = {/home/oel/Dokumente/Papers/Lakhera et al.2025 - Low-temperature chemical synthesis and stabilization of silver nanoparticles for optical power limit.pdf}
}

@article{lasmiSilverNanoparticlesAgNPs2025,
  title = {Silver {{Nanoparticles}} ({{AgNPs}}), {{Methods}} of {{Synthesis}}, {{Characterization}}, and {{Their Application}}: {{A Review}}},
  shorttitle = {Silver {{Nanoparticles}} ({{AgNPs}}), {{Methods}} of {{Synthesis}}, {{Characterization}}, and {{Their Application}}},
  author = {Lasmi, Faouzi and Hamitouche, Houria and {Laribi-Habchi}, Hassiba and Benguerba, Yacine and Chafai, Nadjib},
  year = 2025,
  month = may,
  journal = {Plasmonics},
  volume = {20},
  number = {11},
  pages = {9455--9488},
  issn = {1557-1963},
  doi = {10.1007/s11468-025-02894-9},
  abstract = {Nanotechnology stands at the forefront of rapid advancement, offering versatile applications across diverse industrial sectors. At the heart of this innovation lies nanoparticles (NPs), materials endowed with unique properties that can be scaled down to atomic dimensions. Typically ranging from 1 to 100 nm, these NPs, such as silver nanoparticles (AgNPs), enjoy immense demand spanning consumer goods, pharmaceuticals, healthcare, food, and cosmetics industries. Ensuring their biocompatibility has emerged as a pressing concern in recent times. The multifaceted functionality of AgNPs has spurred their integration into various realms, including water treatment, wound care, diagnostics, orthopedics, nutrition, and as potent antibacterial agents. This proliferation has piqued considerable interest, driving extensive research into their production methodologies. Leveraging their exceptional ability to modulate physical, chemical, and biological attributes, AgNPs offer versatile utility across a spectrum of applications. A comprehensive review of synthesis techniques reveals various approaches, encompassing biological, chemical, physical, electrochemical, medicinal, and green synthesis methods. Among these, the biological route is attractive, boasting simplicity, commercial viability, environmental friendliness, and a streamlined, single-step process devoid of stringent environmental conditions or hazardous chemicals. Before deployment in critical domains such as medicine or healthcare, thorough characterization of manufactured nanoparticles is imperative to mitigate safety concerns. Analytical techniques, including XRD, FTIR, DLS, zeta potential, EDS, XPS, SEM, TEM, AFM, and UV--Vis spectroscopy, offer invaluable insights into the properties of AgNPs. The versatility of AgNPs extends to their diverse therapeutic properties, encompassing anti-tumor, antiviral, antioxidant, anti-cancer, antifungal, antibacterial, anti-inflammatory, and anti-angiogenic effects. This breadth of applications underscores the transformative potential of nanotechnology in addressing complex challenges across myriad domains, heralding a new era of innovation and discovery.},
  langid = {english},
  keywords = {Analytical techniques,Applications,Methods,Nanotechnology,topic/silver-nanoparticles},
  file = {/home/oel/Dokumente/Papers/Lasmi et al.2025 - Silver Nanoparticles (AgNPs), Methods of Synthesis, Characterization, and Their Application A Revie.pdf}
}

@article{mohamedExcitationWavelengthColloids2022,
  title = {Excitation {{Wavelength}} and {{Colloids Concentration-Dependent Nonlinear Optical Properties}} of {{Silver Nanoparticles Synthesized}} by {{Laser Ablation}}},
  author = {Mohamed, Tarek and {El-Motlak}, Majed H. and Mamdouh, Samar and Ashour, Mohamed and Ahmed, Hanan and Qayyum, Hamza and Mahmoud, Alaa},
  year = 2022,
  month = oct,
  journal = {Materials},
  volume = {15},
  number = {20},
  pages = {7348},
  issn = {1996-1944},
  doi = {10.3390/ma15207348},
  abstract = {We reported experimental results from investigations that employed the Z-scan method to explore the dependence of silver nanoparticles' (AgNPs) nonlinear optical properties on the excitation wavelength, AgNP concentration, and size. Using a 532 nm Nd: YAG laser beam at 100 mJ/pulse for different ablation times, AgNPs were synthesized from a silver target immersed in distilled water. UV--Vis spectroscopy and an atomic absorption spectrometer are used to characterize the optical properties of laser-synthesized AgNPs as well as their concentrations. The AgNPs' size and shape are determined using a transmission electron microscope (TEM). The laser-synthesized AgNPs are spherical, with an average particle size of 12 to 13.2 nm. Whatever the ablation time, the AgNP colloids exhibit reversed saturable absorption and a negative nonlinear refractive index (n2). Both n2 and the nonlinear absorption coefficient ({$\alpha$}3) increase as the AgNP concentration increases. As the excitation wavelength and average size of the AgNPs increase, n2 and {$\alpha$}3 decrease.},
  langid = {english},
  keywords = {laser ablation,nonlinear-optics/properties,topic/silver-nanoparticles,Z-Scan},
  file = {/home/oel/Dokumente/Papers/Mohamed et al.2022 - Excitation Wavelength and Colloids Concentration-Dependent Nonlinear Optical Properties of Silver Na.pdf}
}

