@inproceedings{abbasNonlinearOpticalProperties2022,
  title = {Nonlinear {{Optical Properties}} of {{Ag}}/{{PMMA Nanocomposite Thin Films Deposited}} by {{Plasma Jet Polymerization}}},
  booktitle = {2022 4th {{International Conference}} on {{Current Research}} in {{Engineering}} and {{Science Applications}} ({{ICCRESA}})},
  author = {Abbas, Lubna Abdulkareem and Shukur, Sabreen Mhmood and Yahva, Mawadah Glaa},
  year = 2022,
  month = dec,
  pages = {106--109},
  publisher = {IEEE},
  address = {Baghdad, Iraq},
  doi = {10.1109/ICCRESA57091.2022.10352461},
  abstract = {The `nonlinear' optical `properties of silver/PMMA `nanocomposite ` thin films deposited on glass substrates' by in-situ aerosol-assisted plasma jet polymerization at atmospheric `pressure and comfortable ambient temperature from Methyl Meth Acrylate (MMA) monomer in the existence of silver nanoparticles were studied. We used five different concentricities of Ag' nanoparticles,' which were (3, 5, 7, 9, and 11'wt\%). The Z-scan technique was used to 'measure the nonlinear optical properties with a second harmonic generation of pulsed Nd: YAG laser of wavelength 532nm, the energy of 30mJ, and pulse duration of 30ns. The results of open aperture Z-scan show increases in 'nonlinear ` absorption coefficient with silver concentricity increase, while the result of close aperture Z-scan samples show a positive nonlinear refractive index and self-focusing behavior.},
