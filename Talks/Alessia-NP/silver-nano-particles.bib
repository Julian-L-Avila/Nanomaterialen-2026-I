  keywords = {MMA,nanoparticles,nonlinear-optics/properties,plasma polymerization,PMMA,thin films,Z-Scan}
}

@article{abhiramComparativeStudyAuAg2021,
  title = {Comparative {{Study}} on {{Au-Ag}} Composition in {{Lithium Zinc Calcium Fluroborate Glasses}}: {{Nonlinear Optics Perspective}}},
  shorttitle = {Comparative {{Study}} on {{Au-Ag}} Composition in {{Lithium Zinc Calcium Fluroborate Glasses}}},
  author = {Abhiram, J and Rajaramakrishna, R. and Rajashekara, K M and Jagannath, G and Kaewkhao, J. and Rajagukguk, J.},
  year = 2021,
  month = mar,
  journal = {Journal of Physics: Conference Series},
  volume = {1819},
  number = {1},
  pages = {012022},
  issn = {1742-6588, 1742-6596},
  doi = {10.1088/1742-6596/1819/1/012022},
  abstract = {20Li2O-15CaF2-20ZnO-45B2O3- 0.XAu-(0.5-X)  Ag, (where X= 0.2, 0.3) glasses were prepared by the conventional melt quench technique and coded as 2G3S and 3G2S respectively. The idea of this current work is to check the compositional dependence on the gold and silver nanoparticles in the glass. The XRD results confirmed presence of Au-Ag (111) peak at 38.11. The Infrared spectral study confirms the presence of borate segments. The UV Visible Spectroscopic studies confirms the presence of surface plasmon resonance shoulder peak for Ag nanoparticles around 490nm and 509 nm for glass 2G3S and 3G2S which had overlapped with SPR resonance peak of Au around 603 nm for glass 2G3S and around 559nm for glass 3G2S. The nonlinear optical properties were characterized using Z-Scan experimental technique for these glasses and it suggests the Glass 3G2S exhibited better nonlinear refractive index and nonlinear absorption coefficient compared to Glass 2G3S},
  langid = {english},
  keywords = {Au/Ag Nanoparticle doped Glasses,AuNPs,nonlinear-optics/properties,topic/silver-nanoparticles,Z-Scan},
  file = {/home/oel/Dokumente/Papers/AgNPs/Abhiram et al.2021 - Comparative Study on Au-Ag composition in Lithium Zinc Calcium Fluroborate Glasses Nonlinear Optics.pdf}
}

@article{adampourEmulsionstabilizedSilverNanoparticles2025,
  title = {Emulsion-Stabilized Silver Nanoparticles vs. Aqueous Solutions: {{Effects}} on Aggregation, Elastic Scattering, and Nonlinear Optical Properties},
  shorttitle = {Emulsion-Stabilized Silver Nanoparticles vs. Aqueous Solutions},
  author = {Adampour, Shirin and Nezhad, Mehdi Khazaei and Sharifi, Soheil},
  year = 2025,
  month = jul,
  journal = {Colloids and Surfaces A: Physicochemical and Engineering Aspects},
  volume = {717},
  pages = {136795},
  issn = {09277757},
  doi = {10.1016/j.colsurfa.2025.136795},
  abstract = {Silver nanoparticles are stabilized using the stable emulsion developed by mixing water, n-heptane, AOT surfactant, and Ag nanoparticles, and their nonlinear optical characteristics are studied. The plasmonic and nonlinear optical properties of emulsion-stabilized silver nanoparticles are unique due to their placement inside n-heptane and the accumulation of water nanodroplets around them. The optimal concentration and stability time of silver nanoparticles in the emulsion have been investigated to achieve the highest nonlinear absorption coefficient. By comparing the emulsion and aqueous solutions including NaCl, NaOH, L-alanine, and CTAB, a significant increase in nonlinear optical absorption along with elastic light scattering was observed in the emulsion sample, which is the result of increased aggregation of Ag nanoparticles along with a decrease in the dielectric constant of the medium. As a result, the emulsion has been introduced as a tool for modifying the optical properties of Ag nanoparticles. Nonlinear absorption mechanisms, including processes involving free carriers and reverse saturation absorption, are described. Emulsion-stabilized Ag nanoparticles can be used in photodynamic therapy. Since encapsulation enhances nonlinear optical quantities, it can be used as a solution for an effective strategy for the detection and removal of toxic pollutants such as metal ions.},
  langid = {english},
  keywords = {Emulsion,nonlinear-optics,Plasmonic,Surfactant,topic/silver-nanoparticles},
  file = {/home/oel/Dokumente/Papers/Adampour et al.2025 - Emulsion-stabilized silver nanoparticles vs. aqueous solutions Effects on aggregation, elastic scat.pdf}
}

@article{al-hadeethiNanosecondNonlinearOptical2022,
  title = {Nanosecond Nonlinear Optical, Optical Limiting and Structural Properties of {{Eu3}}+ Activated Antimony Sodium Borate Glasses Embedded with Silver Nanoparticles: {{Effect}} of Heat Treatment},
  shorttitle = {Nanosecond Nonlinear Optical, Optical Limiting and Structural Properties of {{Eu3}}+ Activated Antimony Sodium Borate Glasses Embedded with Silver Nanoparticles},
  author = {{Al-Hadeethi}, Yas and Sayyed, M.I. and Barasheed, Abeer Z. and Ahmed, Moustafa and Jagannath, Gangareddy},
  year = 2022,
  month = mar,
  journal = {Optical Materials},
  volume = {125},
  pages = {112106},
  issn = {09253467},
  doi = {10.1016/j.optmat.2022.112106},
  abstract = {Effect of heat treatment on nonlinear optical and optical limiting features of borate based glasses has been ascertained by the Z-scan technique and the results are discussed in detail. The electron microscopic measurements confirmed the existence of spherical shaped Ag nanoparticles and their growth with heat treatment. The values of the two photon absorption coefficient ({$\alpha$}2), nonlinear refractive index (n2) and third-order nonlinear susceptibility ({$\chi$}(3)) showed an increase trend with the increase of the heat treatment duration up to 50 h. Subsequently, the nonlinear optical magnitudes decreased at higher heat treatment durations (for 72 h). The enhancement in the nonlinear optical results of the glasses was attributed to the local field stimulated by silver nanoparticles in the vicinity of the Eu3+ ions in the glass matrices. The optical limiting threshold values demonstrated an opposite trend to that of {$\alpha$}2. The enhancement in {$\alpha$}2 from 2.84 \pounds{} 10 11 to 4.66 \pounds{} 10 11 mW 1 and decrement in optical limiting threshold values from 2.85 \pounds{} 108 to 1.73 \pounds{} 108 Jcm 2 with variation of heat treatment durations from 0 to 50 h suggest the SNBEuAg0.8-50 glass is beneficial for designing the photonic limiters to work in the visible region to suppress the high energy laser radiations.},
  langid = {english},
  keywords = {Antimony borate glasses,Europium ions,Heat treatment,nonlinear-optics/properties,Optical limiting properties,topic/silver-nanoparticles},
  file = {/home/oel/Dokumente/Papers/Al‒Hadeethi et al.2022 - Nanosecond nonlinear optical, optical limiting and structural properties of Eu3+ activated antimony.pdf}
}

@article{al-jumailyCharacterizationNonlinearOptical2025,
  title = {Characterization {{Of Nonlinear Optical Properties Of Silver Nanoparticles At Differently Concentrated Particle Sizes}}},
  author = {{Al-Jumaily}, Anmar K. and Mansour, Tahreer S.},
  year = 2025,
  month = nov,
  journal = {Journal of Optics},
  volume = {54},
  number = {5},
  pages = {3170--3176},
  issn = {0972-8821, 0974-6900},
  doi = {10.1007/s12596-024-02069-5},
  abstract = {The study of nonlinear properties of Silver Nanoparticles (Ag NPs) has increased recently due to its application in all optical switching devices. In this study, the third-order nonlinear optical properties of (Ag NPs) are investigated further with different particle sizes and concentrations. Particles with sizes 10 nm and 20 nm in polyvinyl alcohol (PVA) solution were studied using a Z-scan technique at 980 nm wavelength. Moreover, three different concentrations are investigated particularly 3 mg, 4 mg and 5 mg in the same solution and using the same technique. The values of the nonlinear refractive index (n2) and the nonlinear absorption coefficient ({$\beta$}) were measured and compared according to practical size and concentration of nanoparticles. The nonlinear refractive index (n2) show a negative value for each sample, which act as a divergent lens, due to thermal self-defocusing effect and reverse saturable absorber was observed in Nano solutions due to two-photon absorption process. As a result, the application of these Nano solutions for optical switching devices was investigated by calculate the two figures of merit W and T. Any increase in concentration of Ag NPs makes the solution closer to the suitability condition (W\,{$>$}\,{$>$}\,1 and T\,{$<$}\,1). The Only solution at 20 nm particle size with 5 mg concentration of Ag NPs will satisfy the condition of suitability at W\,=\,2.66 and T\,=\,0.94 for all optical switching applications.},
  langid = {english}
}

@article{chaionSilverNanoparticleBased2025,
  title = {Silver Nanoparticle Based Polymer Composites: Synthesis, Fabrication and Biomedical Applications},
  shorttitle = {Silver Nanoparticle Based Polymer Composites},
  author = {Chaion, Mehedi Hasan and Rabbani, Mahbubay and Rafi, Abu Sayed and Jalil, Mohammad Abdul and Kundu, Chanchal Kumar},
  year = 2025,
  month = dec,
  journal = {Inorganic Chemistry Communications},
  volume = {182},
  pages = {115584},
  issn = {13877003},
  doi = {10.1016/j.inoche.2025.115584},
  abstract = {Silver nanoparticle (AgNP)-based polymer composites have become pioneering materials in biomedical fields through combining the inherent antimicrobial, anti-inflammatory, and anticancer effects of AgNPs. It has been seen that the conventional chemical and physical synthesis methods have been realized as an effective mode of synthesis of AgNPs; they often rely on toxic chemicals or require high energy consumption, prompting a move toward environmentally friendly green synthesis approaches that use plant extracts, microorganisms, and algae. Meanwhile, in the fabrication process, strategies such as in-situ and ex-situ methods allow for precise control over nanoparticle distribution within polymer matrices, improving mechanical strength and functionality. Fabrication techniques, including solvent casting, electrospinning, 3D printing, coating, and layer-by-layer as\- sembly, also produce diverse structures such as nanofibers, thin films, scaffolds, and coatings, which are customized for applications like wound healing, tissue engineering, drug delivery, and biosensing. These com\- posites exhibit strong, broad-spectrum antimicrobial properties, pH-sensitive drug release, and improved biocompatibility, making them essential for infection-resistant implants, intelligent prosthetics, and regenerative medicine. Here, in this review, a thorough overview of recent progress in the synthesis, fabrication, and biomedical applications of these composites is presented, along with their remaining challenges, like cytotoxicity and uncontrolled release, while commenting on potential prospects.},
  langid = {english},
  keywords = {Bio-sensing,Drug delivery systems,Green synthesis,Polymer composites,Tissue engineering,topic/silver-nanoparticles},
  file = {/home/oel/Dokumente/Papers/Chaion et al.2025 - Silver nanoparticle based polymer composites synthesis, fabrication and biomedical applications.pdf}
}

@article{chaoOpticalPropertiesApplications2024,
  title = {Optical Properties and Applications of Metal Nanomaterials in Ultrafast Photonics: A Review},
  shorttitle = {Optical Properties and Applications of Metal Nanomaterials in Ultrafast Photonics},
  author = {Chao, Jiale and Wang, Guangyu and Qiu, Pengtianyu and Sun, Haoqi and Wang, Yachen and Duan, Xuanzhu and Zhang, Jian and Lyu, Yunyu and Ahmad, Ijaz and Fu, Bo},
  year = 2024,
  month = aug,
  journal = {Journal of Materials Science},
  volume = {59},
  number = {29},
  pages = {13433--13461},
  issn = {0022-2461, 1573-4803},
  doi = {10.1007/s10853-024-09993-8},
  abstract = {Metal nanomaterials have emerged as compelling candidates for ultrafast photonics applications, owing to their outstanding saturable absorption properties induced by surface plasmon resonance effects. In recent years, the exploration of saturable absorbers has encompassed noble to non-noble metals as well as diverse structures such as clusters, nanowires and nanoplates. Herein, we comprehensively elucidate the operational principles of metal nanomaterials in ultrafast lasers, including the surface plasmon resonance effect and their complex optical properties. Furthermore, recent advancements in metal nanomaterials utilized in ultrafast lasers have been systematically summarized and classified according to the dimensional structure that profoundly affects their properties. Moreover, the operating parameters of saturable absorbers based on metal nanomaterials are listed in detail. Finally, we look ahead to further directions of metal nanomaterials in ultrafast photonics, presenting explorations in metasurfaces, potential alternatives, and novel integration methods.},
  langid = {english}
}

@article{chevychelovaNonlinearOpticalProperties2021,
  title = {Nonlinear Optical Properties of {{Ag}} Nanoparticles with and without Silicon Dioxide Shell},
  author = {Chevychelova, T.A. and Grevtseva, I.G. and Zvyagin, A.I. and Smirnov, M.S. and Ovchinnikov, O.V. and Ganeev, R.A.},
  year = 2021,
  month = jan,
  journal = {Optical Materials},
  volume = {111},
  pages = {110583},
  issn = {09253467},
  doi = {10.1016/j.optmat.2020.110583},
  abstract = {The features of a nonlinear optical response of the spherical silver nanoparticles with an average size of 20 nm and ``core-shell'' systems based on them (Ag@SiO2) synthesized using the citrate method in the field of nanosecond pulses of the second harmonic of Nd:YAG laser (532 nm) are studied. It is shown that the presence of a SiO2 shell blocks the saturable absorption that occurs due to the photodestruction of silver nanoparticles. The formation of a positive dynamic lens for the Ag@SiO2, which is not typical for the original silver nanoparticles, was detected. An assumption is made about the capture of photo-excited charge carriers by the SiO2 shell.},
  langid = {english},
  keywords = {nonlinear-optics/absorption,Silicon dioxide,topic/silver-nanoparticles,Z-Scan},
  file = {/home/oel/Dokumente/Papers/Chevychelova et al.2021 - Nonlinear optical properties of Ag nanoparticles with and without silicon dioxide shell.pdf}
}

@article{dhanushaMidgapStatesMediated2025,
  title = {Mid-Gap States Mediated Nonlinear Absorption of {{Ag}} Nanoparticles Decorated {{rGO}}/{{MnO2}} Nanocomposites},
  author = {Dhanusha, A. and Sabari Girisun, T.C.},
  year = 2025,
  month = jan,
  journal = {Journal of Alloys and Compounds},
  volume = {1010},
  pages = {177971},
  issn = {09258388},
  doi = {10.1016/j.jallcom.2024.177971},
  abstract = {Engineering complex materials for enhancing the nonlinear optical properties is crucial for photonic applications. Silver metal nanoparticles incorporated reduced graphene oxide (rGO) and manganese dioxide (MnO2) composites with varying Ag concentration were prepared by facile reduction method. X-ray Diffraction (XRD) and Selected Area Electron Diffraction (SAED) exposes the plane orientation of Ag, MnO2, rGO and ensures the composite formation. Raman studies exposes the inclusion of Ag in various wt\% has impacted the defect states of rGO and MnO2 in the composites. Field Emission Scanning Electron Microscope (FESEM) and Transmission Electron Microscopic images (TEM) portraits that at the lower concentration of Ag (0.3--0.5 wt\%), the nanowires of MnO2 were preserved as observed in bare rGO-MnO2 composite and at higher concentration Ag (0.7--1 wt\%), nanowires were recasted into rough spindles thereby influencing the band structure and interfacial interactions. Linear absorption spectra of the composites, deliberately signifies the presence of surface plasmon band (SPR) at 451 nm, {$\pi$} states of graphene at 266 nm and ligand transition of MnO2 at 530 nm. Fluorescence lifetime measurements exposes the probable intersystem crossing ({$\tau$} {$>$} 1 ns) rate by dint of trapped mid-gap states in the composites. Optical nonlinearity of the prepared composites was studied by open aperture (OA) Z-scan method under 532 nm, 9 ns and 10 Hz excitation using Q-switched Nd: YAG laser. At higher Ag concentration (1 wt\%), a peculiar switching behavior from reverse saturable absorption (RSA) (2.22 \texttimes{} 10 10 m/W) to saturable absorption (SA) (-0.22 \texttimes{} 10 10 m/W) with the increase in pump intensity was observed. Meanwhile, the lower Ag content system Ag (0.3 wt\%): rGO/MnO2, possess stronger reverse saturable absorption (8.21 \texttimes{} 10 10 m/W) owing to enhanced field coupling of Ag plasmons and bound mid-gap states of rGO/MnO2. The hierarchical composites possess strong nonlinear absorption than bare rGO, MnO2 and rGO: MnO2 hybrids. Benefiting from the localized SPR of Ag nanoparticles at the interfaces of rGO and MnO2 substantial improvements on the optical nonlinearity of the nanocomposites are procured and thus can be an effective contender for optical limiting and switching applications.},
  langid = {english},
  keywords = {Graphene,Metal nanocomposites,MnO2,Optical limiting,topic/silver-nanoparticles,Z-Scan},
  file = {/home/oel/Dokumente/Papers/Dhanusha and Sabari Girisun2025 - Mid-gap states mediated nonlinear absorption of Ag nanoparticles decorated rGOMnO2 nanocomposites.pdf}
}

@article{elhendawiEnhancementStructureLinear2025,
  title = {Enhancement of the Structure and Linear/Nonlinear Optical Properties of {{PVA}}/Chitosan/{{Ag}} Nanocomposites for Optoelectronic and Antibacterial Applications},
  author = {Elhendawi, H. and Ramadan, R. M. and {Abdel-Aziz}, M. S. and Fahmy, T. and Ali, A. M.},
  year = 2025,
  month = jul,
  journal = {Scientific Reports},
  volume = {15},
  number = {1},
  pages = {27235},
  issn = {2045-2322},
  doi = {10.1038/s41598-025-12029-z},
  abstract = {Abstract                            Polyvinyl alcohol/chitosan/silver (PVA/Cs/Ag) nanocomposites are prepared using casting method for eco-friendly applications. The microstructure and optical properties are investigated using X-ray diffraction, Fourier transform infrared and UV/Vis spectroscopy. XRD analysis revealed that the structural parameters such as lattice strain, crystallites per unit area, dislocation density and stacking fault are affected upon incorporating AgNPs. UV/Vis measurements exhibited that the indirect and direct optical bandgap are reduced from 4.34/5.22~eV for PVA/Cs blend to 3.38/4.78~eV for PVA/Cs/1wt\%Ag nanocomposite. Analysis of Wemple-DiDomenico model exhibited clear enrichment of the linear/nonlinear parameters and it is found that the third order nonlinear optical parameter ({$\chi$}               (3)               ) and nonlinear refractive index, n               2               are enhanced and increased from (0.025\,\texttimes\,10               --12               /0.612\,\texttimes\,10               -12               esu) for PVA/Cs blend to (4.874\,\texttimes\,10               --12               /2.413\,\texttimes\,10               --12               esu) for PVA/Cs/1wt\%Ag nanocomposite. The significant decrease in the energy gap as well as the remarkable change in the nonlinear optical parameters make these materials a strong candidate for many applications in the optoelectronic field. Antibacterial activity measurements strongly suggest that these nanocomposites could be used in the fabrication of antibacterial devices with biomedical applications.},
  langid = {english},
  keywords = {Antibacterial,Chitosan,Dislocation density,Photoconductivity,PVA,topic/silver-nanoparticles},
  file = {/home/oel/Downloads/Elhendawi et al.2025 - Enhancement of the structure and linearnonlinear optical properties of PVAchitosanAg nanocomposit.pdf}
}

@article{elimLargeNonlinearAbsorption2021,
  title = {Large Nonlinear Absorption in Single Aggregate of Silver Nanoparticles Observed with Z-Scan Imaging Technique},
  author = {Elim, Hendry Izaac},
  year = 2021,
  month = nov,
  journal = {AIP Advances},
  volume = {11},
  number = {11},
  pages = {115015},
  issn = {2158-3226},
  doi = {10.1063/5.0062832},
  abstract = {Although nonlinear optical spectroscopy of nanostructures, nanomaterials, and nanomedicines has been widely used to observe and study the nature of nonlinear optical (NLO) phenomena, the field has to improve for the single nanostructure system. However, it is extremely difficult to investigate the nonlinear optical behaviors of single nanostructure materials because the optical setup used in the experiment has to obligate a high resolution imaging arrangement and overcome the diffraction limit problem. This paper presents that a newly modified z-scan technique with imaging as a starting point for nonlinear optics measurement technology has been successfully implemented to investigate silver nanoparticle aggregation. Such single aggregation with a diameter of {$\sim$}1.56 {$\mu$}m made from silver nanoparticles has been precisely observed with an imaging profile on an aggregation target with a large nonlinear absorption coefficient of 8.90 \texttimes{} 109 cm/GW. This technique suggests a wide impact application for a better understanding and knowledge in conjunction with the origin of NLO behavior in any nanomaterials, including nanomedicines.},
  langid = {english},
  keywords = {Nanoparticle,nonlinear-optics,Optical spectroscopy,Saturable absorption,Z-Scan},
  file = {/home/oel/Dokumente/Papers/Elim2021 - Large nonlinear absorption in single aggregate of silver nanoparticles observed with z-scan imaging.pdf}
}

@article{fathimaPlasmonEnhancedLinear2021,
  title = {Plasmon Enhanced Linear and Nonlinear Optical Properties of Natural Curcumin Dye with Silver Nanoparticles},
  author = {Fathima, R. and Mujeeb, A.},
  year = 2021,
  month = may,
  journal = {Dyes and Pigments},
  volume = {189},
  pages = {109256},
  issn = {01437208},
  doi = {10.1016/j.dyepig.2021.109256},
  abstract = {The interactions between silver nanoparticles and bio molecules have potential significance in many interesting applications like sensing, imaging etc. In the present work, the variation in the fluorescence emission and nonlinear optical response of natural Curcumin dye extracted from the Curcuma longa with laser synthesized silver nanoparticles was studied. The formation and optical properties of silver nanoparticles and Curcumin dye solutions were analyzed using UV--Visible absorption spectroscopy, fluorescence emission spectroscopy and fluorescence life time studies. The third order nonlinear optical behavior of the Curcumin dye samples with incorporation of varying concentration of silver nanoparticles were investigated using open aperture Z-scan method. A substantial enhancement was observed for the entire optical behavior such as non-linear optical response, optical limiting properties and fluorescence emission of the Curcumin samples with silver nanoparticles, which progressively improved with the concentration of the silver nanoparticles incorporated into the system.},
  langid = {english},
  keywords = {Curcumin,Fluorescence enhancement,nonlinear-optics/properties,topic/silver-nanoparticles,Z-Scan},
  file = {/home/oel/Dokumente/Papers/Fathima and Mujeeb2021 - Plasmon enhanced linear and nonlinear optical properties of natural curcumin dye with silver nanopar.pdf}
}

@article{ganjiNonlinearOpticalStructural2025,
  title = {Nonlinear Optical and Structural Properties of Silver Nanoparticle-Embedded Borotellurite Glasses},
  author = {Ganji, Priyanka V and Pasha, U.Mahaboob and Reddy, N.Sivasankara and Joseph, C.M.},
  year = 2025,
  month = dec,
  journal = {Ceramics International},
  volume = {51},
  number = {30},
  pages = {64949--64966},
  issn = {02728842},
  doi = {10.1016/j.ceramint.2025.11.054},
  abstract = {Ag nanoparticles embedded borotellurite glasses were synthesized using traditional melt quenching method. Measurements of X-ray diffraction confirms the amorphous glassy behaviour of the samples. FTIR analysis and its deconvoluted spectra were used to identify the presence of TeO3+1 polyhedral and TeO3 trigonal pyramidal units. Raman study reveals the presence of diborate, dipentaborate and metaborate chain vibrations. The optical studies such as absorbance, indirect bandgap, Urbach energy, refractive index, oxide ion polarizability, optical basicity were analysed. HR-TEM analysis confirmed the existence of uniformly distributed spherical shaped Ag NPs, with an increase in the particle size. Elemental mapping verified the existence of Ag NPs and also indicated the homogeneous distribution of all the compounds in the glass matrix. Z-scan measurements were employed to confirm the non-linear optical (NLO) behaviour of the synthesized glass samples. Open aperture mode was used to analyze nonlinear absorption coefficient ({$\alpha$}2) and it confirmed the presence of pure reverse saturable absorption (RSA), whereas closed aperture mode was utilized to determine nonlinear refractive index (n2). The increment of Ag NPs lead to an increase of {$\alpha$}2 and n2. The NLO data revealed that the glasses under investigation are promising candidates for nonlinear optical applications.},
  langid = {english},
  keywords = {Borotellurite glasses,Dipentaborate,nonlinear-optics,Raman,Thermal stability},
  file = {/home/oel/Dokumente/Papers/Ganji et al.2025 - Nonlinear optical and structural properties of silver nanoparticle-embedded borotellurite glasses.pdf}
}

@article{gonzalez-campuzanoSaturableAbsorptionNegative2023,
  title = {Saturable Absorption and Negative Nonlinear Refraction Index Evolution in Silver Nanoparticles Colloids},
  author = {{Gonz{\'a}lez-Campuzano}, R. and {Delgado-Aguill{\'o}n}, J. and {Sato-Berr{\'u}}, R.Y. and {Sainz-Vidal}, A. and {Rodr{\'i}guez-Rosales}, A.A. and {Rom{\'a}n-Moreno}, C.J. and {Gardu{\~n}o-Mej{\'i}a}, J.},
  year = 2023,
  month = apr,
  journal = {Optics \& Laser Technology},
  volume = {159},
  pages = {108989},
  issn = {00303992},
  doi = {10.1016/j.optlastec.2022.108989},
  abstract = {In this paper, silver nanoparticles colloids in deionized water with evolution from spherical to disk and decahedral shapes, and average size between {$\sim$}10--50 nm, were synthesized controlling the reaction conditions. The samples were irradiated using a cool-white light-emitting diode source for several hours, which allowed the tailoring of the position of the surface plasmon resonance from 408 nm to 495 nm. The nonlinear optical properties of silver nanoparticles colloids were investigated by the Z-scan technique and femtosecond laser pulses @ 800 nm. The nonlinear absorption obtained by an open aperture Z-scan setup showed a saturable absorption effect, while the nonlinear refraction index measured by a close aperture setup revealed a negative lens-like (self-defocusing) behavior in all samples. Measured effective nonlinear absorption ranged from -5.26 \texttimes{} 10-9 to -1.03 \texttimes{} 10-9 cm/W, while nonlinear refractive index was -2.47 \texttimes{} 10-13 to -1.48 \texttimes{} 10-13 cm2/W. We found that as the silver nanoparticles shape is modified from quasi-spherical to disk and decahedral, and its size is increased, the linear absorption and the absolute values of the effective nonlinear absorption and nonlinear refractive index decreased. We also found that the nonlinear optical response is more sensitive to size and morphology than the linear optical response.},
  langid = {english},
  keywords = {Nonlinear absorption,Nonlinear refraction,nonlinear-optics/properties,Saturable absorption,topic/silver-nanoparticles,Z-Scan},
  file = {/home/oel/Dokumente/Papers/González-Campuzano et al.2023 - Saturable absorption and negative nonlinear refraction index evolution in silver nanoparticles collo.pdf}
}

@article{hosnyComprehensiveReviewSilver2025,
  title = {A {{Comprehensive Review}} of {{Silver Nanoparticles}} ({{AgNPs}}): {{Synthesis Strategies}}, {{Toxicity Concerns}}, {{Biomedical Applications}}, {{AI-Driven Advancements}}, {{Challenges}}, and {{Future Perspectives}}},
  shorttitle = {A {{Comprehensive Review}} of {{Silver Nanoparticles}} ({{AgNPs}})},
  author = {Hosny, Shimaa and Gaber, Ghalia A. and Ragab, Mona S. and Ragheb, Mohamed A. and Anter, Mena and Mohamed, Lamiaa Z.},
  year = 2025,
  month = sep,
  journal = {Arabian Journal for Science and Engineering},
  issn = {2193-567X, 2191-4281},
  doi = {10.1007/s13369-025-10612-0},
  abstract = {Silver nanoparticles (AgNPs) have garnered considerable attention due to their remarkable antimicrobial and biomedical properties. This review offers a comprehensive overview of AgNP synthesis methods, stability factors, toxicity concerns, and future research directions, including advancements driven by artificial intelligence (AI). Various synthesis approaches, including physical, chemical, electrochemical, photochemical, and biological methods, are explored, with particular emphasis on sustainable alternatives such as plant-based synthesis, as well as bacterial, fungal, and algal-mediated methods. Key factors influencing AgNP stability, such as size, shape, and surface modifications, are examined to assess their impact on functionality and overall performance. The biomedical applications of AgNPs, including their roles in antimicrobial treatments, wound healing, drug delivery, and cancer therapy, are reviewed alongside concerns about cytotoxicity and environmental implications. Nonetheless, we still have gaps in our understanding of the long-term biological impacts and our capacity to build consistent synthesis procedures. Challenges in AgNP synthesis, such as scalability, reproducibility, and controlled functionalization, are also discussed. Additionally, the integration of AI in AgNP research is highlighted, showcasing its potential in optimizing synthesis parameters, predicting stability, and enhancing material performance. This review aims to provide a thorough understanding of AgNP synthesis, stability, and biomedical applications while addressing toxicity issues and emphasizing the AI role in advancing nanoparticle research. This integration is a unique feature of the current article, as it has rarely been explored in previous studies. Finally, future perspectives and research directions are outlined to address existing challenges and drive further innovation in AgNP development with an emphasis on applying AI technology to overcome existing synthesis restrictions, improve repeatability, and promote intelligent AgNP-based medicinal platform design.},
  langid = {english},
  keywords = {Artificial intelligence-driven advancements,Biomedical applications,Future challenges,Stability factors,Synthesis,topic/silver-nanoparticles,Toxicity},
  file = {/home/oel/Dokumente/Papers/Hosny et al.2025 - A Comprehensive Review of Silver Nanoparticles (AgNPs) Synthesis Strategies, Toxicity Concerns, Bio.pdf}
}

@article{jagannathanPrecursorBasedTuning2021,
  title = {Precursor {{Based Tuning}} of the {{Nonlinear Optical Properties}} of {{Au-Ag Bimetallic Nanoparticles Doped}} in {{Oxy-fluoroborate Glasses}}},
  author = {Jagannathan, Abhiram and Gangareddy, Jagannath and Rajaramakrishna, R. and Rajashekara, K.M. and Rao, S. Venugopal and Kaewkhao, J and Kothan, S and {El-Denglawey}, A.},
  year = 2021,
  month = jun,
  journal = {Journal of Non-Crystalline Solids},
  volume = {561},
  pages = {120766},
  issn = {00223093},
  doi = {10.1016/j.jnoncrysol.2021.120766},
  abstract = {This work brings out the importance of precursors (AgNO3, AgCl, and AgI) that involve in tailoring the optical properties for the Au-Ag bimetallic nanoparticles doped in the dichroic glasses. The incorporation of silver nanoparticles in 20Li2O-15CaF2-20ZnO-45B2O3 matrix along with gold has reduced the average size of nanoparticle and has enhanced the nonlinear refractive index. The absorption spectra hints that there could be the possibility of surface plasmon resonance (SPR) overlap of Ag and Au as there is no prominent peak of Ag nanoparticles in the blue region. It is found that the sample doped with Au-AgNO3 has lesser bandgap energy compared to Au-AgCl and Au-AgI respectively which had thereby increased more NBO's in the matrix which in turn results in better nonlinear optical properties for Au-Ag NO3.},
  langid = {english},
  keywords = {AuNPs,Fluoroborate glasses,nonlinear-optics/properties,Optical limiting,Surface plasmon resonance,topic/silver-nanoparticles},
  file = {/home/oel/Dokumente/Papers/Jagannathan et al.2021 - Precursor Based Tuning of the Nonlinear Optical Properties of Au-Ag Bimetallic Nanoparticles Doped i.pdf}
}

@article{jiangDoubleTransformationNonlinear2022,
  title = {Double Transformation of the Nonlinear Absorption in Silver Nanoparticles},
  author = {Jiang, Jijuan and Zuo, Shiyi and Wang, Guan and Liu, Jia and Zhang, Xiaoming and Gao, Yachen},
  year = 2022,
  month = nov,
  journal = {Optics Express},
  volume = {30},
  number = {23},
  pages = {41255},
  issn = {1094-4087},
  doi = {10.1364/OE.472705},
  abstract = {The nonlinear absorption of 40 nm Ag nanoparticles (Ag NPs) was investigated using open aperture (OA) Z-scan technique at 532 nm. Experiments show that the nonlinear absorption behavior of Ag NPs is intensity dependent. Specifically, under low laser energy the Ag NPs shows saturable absorption (SA). At medium laser energy, the transformation of nonlinear absorption from SA to reverse saturable absorption (RSA) happens. While under stronger laser energy, double transformation (SA{$\rightarrow$}RSA{$\rightarrow$}SA) of nonlinear absorption occurs. The experimental results were analyzed theoretically using a model based on single-photon absorption and two-photon absorption saturation.},
  langid = {english},
  file = {/home/oel/Dokumente/Papers/Jiang et al.2022 - Double transformation of the nonlinear absorption in silver nanoparticles.pdf}
}

@article{jiangSizeEffectNonlinear2022,
  title = {Size Effect on Nonlinear Optical Properties and Ultrafast Dynamics of Silver Nanoparticles},
  author = {Jiang, Jijuan and Miao, Fengjuan and Wu, Wenzhi and Kong, Degui and Ridi, Buyinga and Gao, Yachen},
  year = 2022,
  month = may,
  journal = {Optics Express},
  volume = {30},
  number = {11},
  pages = {19533},
  issn = {1094-4087},
  doi = {10.1364/OE.453627},
  abstract = {Z-scan technology was used to study the nonlinear absorption (NLA) and nonlinear refraction (NLR) of silver nanoparticles (Ag NPs) with various sizes under different laser intensities. The results demonstrate that the NLA and NLR of Ag NPs were size-dependent. Specifically, the 10 nm Ag NPs exhibit saturation absorption (SA) and insignificant NLR. The 20 and 40 nm Ag NPs show the coexistence of SA and reverse saturation absorption (RSA). SA is believed to result from ground-state plasma bleaching, whereas RSA originates from excited state absorption (ESA). The 20 nm and 40 nm Ag NPs shows increasing self-defocusing with the increase of laser intensity. It was observed that the energy relaxation of Ag NPs mainly includes two processes of electron-phonon and phonon-phonon couplings on the order of picoseconds.},
  langid = {english},
  file = {/home/oel/Dokumente/Papers/Jiang et al.2022 - Size effect on nonlinear optical properties and ultrafast dynamics of silver nanoparticles.pdf}
}

@article{josephBiogenicSilverNanoparticles2026,
  title = {Biogenic Silver Nanoparticles Using {{Schleichera}} Oleosa Leaf Extract: Nonlinear Optical Applications},
  shorttitle = {Biogenic Silver Nanoparticles Using {{Schleichera}} Oleosa Leaf Extract},
  author = {Joseph, Mary and Thomas, Rakhi and Lazar, Manoj A and Andrews, Jolly and Philip, Reji and Anand, Benoy},
  year = 2026,
  month = jan,
  journal = {Physics Letters A},
  volume = {565},
  pages = {131164},
  issn = {03759601},
  doi = {10.1016/j.physleta.2025.131164},
  abstract = {This work reports the biosynthesis of silver nanoparticles (Ag NPs) using Schleichera oleosa leaf extract and its nonlinear optical (NLO) properties. UV--Visible absorption spectroscopy confirmed the formation of Ag NPs with a characteristic surface plasmon resonance peak at 416 nm. X--ray diffraction studies revealed their crystalline nature, while transmission electron microscopy showed uniform spherical nanoparticles with an average size of 27.7 nm. FTIR analysis identified biomolecules in Schleichera oleosa leaf extract responsible for reducing and capping the nanoparticles. The nonlinear optical response is evaluated using the open--aperture Z--scan technique under nanosecond laser excitation at 532 nm. At lower excitation energies, the nanoparticles display saturable absorption, which switches to reverse saturable absorption at higher excitation energies. These findings underscore the potential use of green--synthesized Ag NPs in optical limiting and optical switching applications.},
  langid = {english},
  keywords = {Green synthesis,nonlinear-optics,Optical limiting,Schleichera oleosa,topic/silver-nanoparticles},
  file = {/home/oel/Dokumente/Papers/Joseph et al.2026 - Biogenic silver nanoparticles using Schleichera oleosa leaf extract nonlinear optical applications.pdf}
}

@article{kannaiahAntibacterialCytotoxicEffect2026,
  title = {Antibacterial and Cytotoxic Effect of Green Synthesized Silver Nanoparticles Using {{Solanum}} Torvum Fruit Pedicel Waste Extract},
  author = {Kannaiah, Surendirakumar and Paramasivam, Suguna and Sanasam, Bandana and Sekar, Narmatha and Nongthombam, Kistu Singh and Palanivel, Kavitha and Pandiyan, Jeevan},
  year = 2026,
  month = jan,
  journal = {Discover Biotechnology},
  volume = {3},
  number = {1},
  pages = {2},
  issn = {3004-8907},
  doi = {10.1007/s44340-026-00049-y},
  abstract = {Vegetable waste is a promising bioresource for the production of nanomaterials. The eco-friendly synthesis of metallic nanoparticles is gaining attention among materials scientists, as biomolecules in vegetable waste show significant potential for nanoparticle synthesis. In the current study, an aqueous fruit pedicel extract of Solanum torvum was employed to produce silver nanoparticles (ST@AgNPs) using a green synthesis technique. UV-visible spectrum study corroborated the phytofabrication of ST@AgNPs, revealing a unique surface plasmon resonance peak at 418 nm. The FTIR spectra were used to identify the efficient functional molecules that act as capping and stabilizing agents, as well as those that convert Ag + to nanosilver (Ag0). FE-SEM, TEM, and XRD indicated the crystalline nature of the spherical ST@AgNPs with an average size of \textasciitilde{} 108 nm. Stability analysis indicates particle stability, with a surface charge of -16.2 mV based on zeta potential measurements. Antibacterial assays demonstrated significant inhibition of human pathogenic bacteria, including Staphylococcus aureus, Klebsiella pneumoniae, Pseudomonas aeruginosa and Staphylococcus haemolyticus. The results of the agar broth dilution assay exhibited potential bacterial colony reduction at the lowest dose of ST@Ag-NPs. The results of the MTT cytotoxicity assay exhibit an anticancer efficacy against A549 lung cancer cells, with an IC{$_{50}$} value of 38.2 \textpm{} 0.8 \textmu g/mL. This is the first study to examined the biogenesis and biological activity of ST@Ag-NPs derived from S. torvum fruit pedicel debris. These findings suggest that ST@Ag-NPs are effective for antibacterial and anticancer applications and may serve as a low-cost, bioactive therapeutic for future biomedical use.},
  langid = {english},
  keywords = {Antibacterial,Biogenic silver,Food waste valorization,Green nanotechnology,MTT assay,nanoparticles,Solanum torvum fruit pedicel,Sustainable management},
  file = {/home/oel/Dokumente/Papers/Kannaiah et al.2026 - Antibacterial and cytotoxic effect of green synthesized silver nanoparticles using Solanum torvum fr.pdf}
}

@article{kelaniComparingSilverGold2024,
  title = {Comparing Silver and Gold Nanoislands' Surface Plasmon Resonance for Bisacodyl and Its Metabolite Quantification in Human Plasma},
  author = {Kelani, Khadiga M. and Ibrahim, Maha M. and Ramadan, Nesreen K. and Elzanfaly, Eman S. and Eid, Sherif M.},
  year = 2024,
  month = mar,
  journal = {BMC Chemistry},
  volume = {18},
  number = {1},
  pages = {56},
  issn = {2661-801X},
  doi = {10.1186/s13065-024-01157-8},
  abstract = {Gold and silver nanoparticles have witnessed increased scientific interest due to their colourful colloidal solutions and exceptional applications. Comparing the localized surface plasmon resonance (LSPR) of gold and silver nanoparticles is crucial for understanding and optimizing their optical properties. This comparison informs the design of highly sensitive plasmonic sensors, aids in selecting the most suitable nanoparticles for applications like surface-enhanced infrared spectroscopy (SEIRA) and biomedical imaging, and guides the choice between gold and silver nanoparticles based on their catalytic and photothermal properties. Ultimately, the study of LSPR facilitates the tailored use of these nanoparticles in diverse scientific and technological applications. Two SEIRA methods combined with partial least squares regression (PLSR) chemometric tools were developed. This development is based on the synthesis of homogeneous, high-dense deposited metal nanoparticle islands over the surface of glass substrates to be used as lab-on-chip SEIRA sensors for the determination of bisacodyl (BIS) and its active metabolite in plasma. SEM micrographs revealed the formation of metallic islands of colloidal citrate-capped gold and silver nanoparticles of average sizes of 29.7 and 15~nm, respectively. BIS and its active metabolite were placed on the nanoparticles' coated substrates to be directly measured, then PLSR chemometric modelling was used for the quantitative determinations. Plasmonic citrate-capped gold nanoparticle substrates showed better performance than those prepared using citrate-capped silver nanoparticles in terms of preparation time, enhancement factor, PLSR model prediction, and quantitative results. This study offers a way to determine BIS and its active metabolite in the concentration range 15--240 ng/mL in human plasma using inexpensive disposable glass-coated substrates that can be prepared in 1~h to get results in seconds with good recovery between 98.77 and 100.64\%. The sensors provided fast, simple, selective, molecular-specific and inexpensive procedures to determine molecules in their pure form and biological fluid.},
  langid = {english},
  keywords = {Bisacodyl,Localized surface plasmon resonance,Optical biosensor,Partial least squares,Plasma,Surface-enhanced infrared absorption spectroscopy},
  file = {/home/oel/Dokumente/Papers/Kelani et al.2024 - Comparing silver and gold nanoislands’ surface plasmon resonance for bisacodyl and its metabolite qu.pdf}
}

@article{kocSilverNanoparticlesAgNPs2026,
  title = {Silver Nanoparticles ({{AgNPs}}) as Broad-Spectrum Antimicrobial Agents: Synthesis, Mechanisms of Action, and Applications},
  shorttitle = {Silver Nanoparticles ({{AgNPs}}) as Broad-Spectrum Antimicrobial Agents},
  author = {Ko{\c c}, M{\"u}min Mehmet and {\"O}zcan, {\"O}zge and {\.I}nal Kabala, Sevilay},
  year = 2026,
  month = mar,
  journal = {Journal of the Korean Physical Society},
  issn = {0374-4884, 1976-8524},
  doi = {10.1007/s40042-026-01606-8},
  abstract = {Silver nanostructures have awakened considerable interest due to their extensive antimicrobial capabilities, including antibacterial, antiviral, and antifungal uses. This review highlights the influence of production techniques on the dimensions, shape, and multimodal functionalities of these nanoparticles. Essential production processes, including chemical reduction, green synthesis, and physical procedures, which provide meticulous control over the properties of nanostructures, were also assessed. Chemical approaches, including reduction processes, ensure scalability and consistency, whereas green synthesis presents an environmentally sustainable option by utilizing plant extracts and microorganisms to generate biocompatible nanoparticles. Silver nanostructures demonstrate significant antibacterial efficacy via mechanisms including enzyme inhibition, cell wall disintegration, and DNA damage, successfully addressing drug-resistant bacterial pathogens. Likewise, their antifungal characteristics specifically target fungal biofilms and disrupt membrane integrity, demonstrating potential efficacy against various strains. Moreover, silver nanostructures exhibit antiviral properties by interfering with protein synthesis, disrupting viral replication, and preventing the entry of viruses into host cells, thereby demonstrating efficacy against many viral infections. The multimodal properties of silver nanostructures, encompassing both antibacterial and antioxidant actions, augment their utility in medical and industrial sectors. Notwithstanding these benefits, cytotoxicity continues to be a significant issue, requiring sophisticated synthesis methods to enhance safety and efficacy. This thorough analysis emphasizes silver nanostructures as essential instruments in combating microbial resistance, highlighting their potential in novel therapeutic applications. In contrast to traditional studies, this research addresses the antibacterial properties of silver nanoparticles connected to the production process. However, in order to maximize the potential of the nanoparticles and support future research, potential limitations and disadvantages were also explored.},
  langid = {english},
  keywords = {Antibacterial,Antifungal,Antiviral,Nanoparticle synthesis,topic/silver-nanoparticles}
}

