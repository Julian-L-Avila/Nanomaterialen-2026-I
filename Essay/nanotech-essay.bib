  doi = {10.15446/rev.colomb.quim.v45n1.58955},
  abstract = {Debido a la creciente producci\'on y uso de nanomateriales para actividades de investigaci\'on y desarrollo en Colombia, es necesario establecer una definici\'on del t\'ermino nanomaterial que facilite la toma de decisiones en torno a iniciativas de car\'acter regulatorio y de normatividad. Se presenta la definici\'on de nanomateriales para Colombia que ha adoptado el Consejo Nacional Asesor de Nanociencia y Nanotecnolog\'ia adscrito a la Red Colombiana de Nanociencia y Nanotecnolog\'ia.},
